{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Qorelly Docs",
  "colors": {
    "primary": "#6B46FF",
    "light": "#8B5CF6",
    "dark": "#5B35EF"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart",
              "business-types"
            ]
          },
          {
            "group": "Platform Features",
            "pages": [
              "platform/dashboard",
              "platform/menu-management",
              "platform/point-of-sale",
              "platform/inventory",
              "platform/bookings",
              "platform/customers",
              "platform/team-management",
              "platform/digital-menu"
            ]
          },
          {
            "group": "Settings & Configuration",
            "pages": [
              "platform/settings",
              "platform/locations",
              "platform/apps-modules"
            ]
          }
        ]
      },
      {
        "tab": "Mobile App",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "mobile/overview",
              "mobile/app-modes"
            ]
          },
          {
            "group": "Mobile Features",
            "pages": [
              "mobile/offline-mode",
              "mobile/receipt-printing",
              "mobile/barcode-scanning"
            ]
          }
        ]
      },
      {
        "tab": "Administration",
        "groups": [
          {
            "group": "Access Control",
            "pages": [
              "administration/roles-permissions",
              "administration/terminal-mode"
            ]
          },
          {
            "group": "Multi-Tenant",
            "pages": [
              "administration/workspaces",
              "administration/multi-location"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://qorelly.com",
          "icon": "globe"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@qorelly.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://qorelly.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/qorelly",
      "instagram": "https://www.instagram.com/useqorelly"
    }
  },
  "description": "Documentation for Qorelly — the business management and POS platform for restaurants, spas, pharmacies, retail stores, fuel stations, and more."
}
